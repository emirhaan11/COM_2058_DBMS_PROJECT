<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane xmlns="http://javafx.com/fxml" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="dbms_project.controller.EmployerDashboardController"
         prefWidth="900" prefHeight="450"
        >

    <Tab text="Publish New Post" closable="false">
        <VBox spacing="10" style="-fx-padding: 20;">
            <TextField fx:id="jobTitleField" promptText="Job Title"/>
            <TextArea fx:id="jobDescArea" promptText="Job Definition" prefHeight="200"/>
            <TextField fx:id="salaryField" promptText="Salary Range"/>
            <Button text="Publish the Post" onAction="#handlePostJob" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>

            <HBox alignment="TOP_RIGHT" style="-fx-padding: 10;">
                <Button text="Exit" onAction="#handleLogout" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </Tab>

    <Tab text="İlanlarım" closable="false">
        <VBox spacing="10" style="-fx-padding: 10;">

            <TableView fx:id="myJobsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Başlık" fx:id="colMyTitle" prefWidth="150"/>
                    <TableColumn text="Açıklama" fx:id="colMyDesc" prefWidth="300"/>
                    <TableColumn text="Durum" fx:id="colMyStatus" prefWidth="100"/>
                    <TableColumn text="Tarih" fx:id="colMyDate" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button text="Seçili İlanı Sil" onAction="#handleDeleteJob" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                <Button text="Yetenekleri Gör" onAction="#handleViewJobSkills" style="-fx-background-color: #607D8B; -fx-text-fill: white;"/>
            </HBox>

            <TitledPane text="Seçili İlana Aranan Yetenek Ekle" collapsible="false">
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10;">
                    <TextField fx:id="empSkillNameField" promptText="Yetenek Adı (Örn: Java)" prefWidth="200"/>
                    <CheckBox fx:id="mandatoryCheck" text="Zorunlu Yetenek"/>
                    <Button text="İlana Ekle" onAction="#handleAddJobSkill" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
            </TitledPane>

        </VBox>
    </Tab>

    <Tab text="Tüm İlanlar" closable="false">
        <VBox spacing="10" style="-fx-padding: 10;">

            <TableView fx:id="allJobsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Şirket" fx:id="colAllCompany" prefWidth="150"/>
                    <TableColumn text="Başlık" fx:id="colAllTitle" prefWidth="150"/>
                    <TableColumn text="Açıklama" fx:id="colAllDesc" prefWidth="300"/>
                    <TableColumn text="Maaş" fx:id="colAllSalary" prefWidth="100"/>
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button onAction="#handleViewJobSkills" text="View Job Details/Skills" style="-fx-background-color: #607D8B; -fx-text-fill: white;" />
            </HBox>

        </VBox>
    </Tab>

    <Tab text="Gelen Başvurular" closable="false">
        <VBox spacing="10" style="-fx-padding: 10;">
            <TableView fx:id="applicationTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="Aday" fx:id="colSeekerName"/>
                    <TableColumn text="İlan" fx:id="colJobTitle"/>
                    <TableColumn text="Durum" fx:id="colStatus"/>
                </columns>
            </TableView>

            <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                <Button text="Reddet (Rejected)" onAction="#handleRejectApplication" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Kabul Et (Accepted)" onAction="#handleAcceptApplication" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </Tab>
</TabPane>