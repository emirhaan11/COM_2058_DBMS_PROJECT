<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="15.0"
      style="-fx-background-color: #f4f4f9;" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="dbms_project.controller.LoginController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="JOBJOB.NET" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333;" />

    <TextField fx:id="emailField" promptText="E-mail" style="-fx-padding: 10px; -fx-background-radius: 5px;" />

    <PasswordField fx:id="passwordField" promptText="Password" style="-fx-padding: 10px; -fx-background-radius: 5px;" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Login" onAction="#handleLogin" prefWidth="120"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 5px; -fx-font-weight: bold;"/>
        <Button text="Register" onAction="#handleRegister" prefWidth="120"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 5px; -fx-font-weight: bold;"/>
    </HBox>
</VBox>