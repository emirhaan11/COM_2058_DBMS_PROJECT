<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TabPane prefHeight="700" prefWidth="1050" stylesheets="@style.css"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="dbms_project.controller.SeekerDashboardController">

    <Tab text="Profile &amp; CV" closable="false">
        <VBox spacing="20" style="-fx-padding: 30;">
            <VBox styleClass="card" spacing="20" VBox.vgrow="ALWAYS">
                <Label text="Personal Information" styleClass="header-label" />
                <Separator/>
                <HBox spacing="15">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="First Name" styleClass="subheader-label"/>
                        <TextField fx:id="fnameField" promptText="First Name" />
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Last Name" styleClass="subheader-label"/>
                        <TextField fx:id="lnameField" promptText="Last Name" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-margin-top: 10px;">
                    <Button onAction="#handleUpdateProfile" styleClass="btn-success" text="Save Profile Changes" />
                </HBox>
            </VBox>

            <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
                <Label text="Resume / CV Upload" styleClass="header-label" />
                <Separator/>
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Button onAction="#handleUploadCV" text="Upload PDF CV" styleClass="btn-primary"/>
                    <Label fx:id="cvPathLabel" text="No file selected." style="-fx-text-fill: #6B7280; -fx-font-style: italic;"/>
                </HBox>
            </VBox>

            <HBox alignment="BOTTOM_RIGHT" VBox.vgrow="ALWAYS">
                <Button text="Logout" onAction="#handleLogout" styleClass="btn-danger"/>
            </HBox>
        </VBox>
    </Tab>

    <Tab text="Education &amp; Experience" closable="false">
        <HBox spacing="20" style="-fx-padding: 20;">
            <!-- EDUCATION SECTION -->
            <VBox styleClass="card" spacing="15" HBox.hgrow="ALWAYS">
                <Label text="Education History" styleClass="header-label" />
                <TableView fx:id="educationTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colInstitution" text="Institution" />
                        <TableColumn fx:id="colDepartment" text="Department" />
                        <TableColumn fx:id="colDegree" text="Degree" />
                        <TableColumn fx:id="colGradYear" text="Year" />
                    </columns>
                </TableView>

                <VBox spacing="10">
                    <HBox spacing="10">
                        <TextField fx:id="instField" promptText="Institution" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="deptField" promptText="Department" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <TextField fx:id="degreeField" promptText="Degree" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="gradYearField" promptText="Year" HBox.hgrow="ALWAYS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Add" onAction="#handleAddEducation" styleClass="btn-success"/>
                    </HBox>
                </VBox>
                <Button text="Delete Selected" onAction="#handleDeleteEducation" styleClass="btn-danger" maxWidth="Infinity"/>
            </VBox>

            <!-- EXPERIENCE SECTION -->
            <VBox styleClass="card" spacing="15" HBox.hgrow="ALWAYS">
                <Label text="Work Experience" styleClass="header-label" />
                <TableView fx:id="experienceTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colExpCompany" text="Company" />
                        <TableColumn fx:id="colRole" text="Role" />
                        <TableColumn fx:id="colStartDate" text="Start Date" />
                        <TableColumn fx:id="colEndDate" text="End Date" />
                    </columns>
                </TableView>

                <VBox spacing="10">
                    <HBox spacing="10">
                        <TextField fx:id="expCompField" promptText="Company Name" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="expRoleField" promptText="Role" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="10">
                        <DatePicker fx:id="startDatePicker" promptText="Start Date" HBox.hgrow="ALWAYS"/>
                        <DatePicker fx:id="endDatePicker" promptText="End Date" HBox.hgrow="ALWAYS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Add" onAction="#handleAddExperience" styleClass="btn-success"/>
                    </HBox>
                </VBox>
                <Button text="Delete Selected" onAction="#handleDeleteExperience" styleClass="btn-danger" maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </Tab>

    <Tab text="Job Search" closable="false">
        <VBox spacing="20" style="-fx-padding: 20;">
            <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
                <Label text="Available Postings" styleClass="header-label"/>
                <TableView fx:id="jobPostingTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colCompany" text="Company" />
                        <TableColumn fx:id="colTitle" text="Job Title" />
                        <TableColumn fx:id="colDescription" text="Description" />
                    </columns>
                </TableView>
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button onAction="#handleViewJobSkills" text="View Requirements" styleClass="btn-secondary" />
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button onAction="#handleSaveJob" text="Save Job" styleClass="btn-primary" />
                    <Button onAction="#handleApplyJob" text="Apply Now" styleClass="btn-success" />
                </HBox>
            </VBox>
        </VBox>
    </Tab>

    <Tab text="My Skills" closable="false">
        <VBox spacing="20" style="-fx-padding: 30;">
            <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
                <Label text="Manage Your Skillset" styleClass="header-label" />
                <Separator/>
                <TableView fx:id="skillTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colSkillName" text="Skill Name" />
                        <TableColumn fx:id="colProficiency" text="Proficiency Level" />
                    </columns>
                </TableView>

                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-margin-top: 10px;">
                    <TextField fx:id="skillNameField" promptText="e.g. OpenCV, React, SQL" HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="proficiencyCombo" promptText="Select Level" HBox.hgrow="ALWAYS"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Add Skill" onAction="#handleAddSkill" styleClass="btn-success"/>
                </HBox>
            </VBox>
        </VBox>
    </Tab>
</TabPane>